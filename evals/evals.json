{
  "skill_name": "agent-skills-creator",
  "version": "1.6.0",
  "description": "Agent Skills Creator 评估数据集 v1.6.0，包含多轮训练、多 Agent 协作、质量验证、模式检测等关键场景",
  "evals": [
    {
      "id": "create-new-skill",
      "description": "测试创建新 Skill 的标准化能力",
      "mode": "CREATE",
      "turns": [
        {
          "role": "user",
          "content": "使用 agent-skills-creator 创建一个 code-review Skill"
        }
      ],
      "should_trigger": true,
      "expected_tool_calls": [
        {"server": "FileSystem", "tool": "create_directory_structure"}
      ],
      "assertions": [
        {"type": "skill_structure_valid", "value": true},
        {"type": "yaml_frontmatter_complete", "value": true}
      ],
      "rubric_score_target": 95
    },
    {
      "id": "multi-agent-collaboration",
      "description": "测试多 Agent 协作模式（层次 + 并行）",
      "mode": "CREATE",
      "turns": [
        {
          "role": "user",
          "content": "对 git-release Skill 进行多 Agent 协作处理，使用层次模式 + 并行子 Agent"
        }
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "multi_agent_used", "value": true},
        {"type": "delta_positive", "value": true},
        {"type": "collaboration_log_generated", "value": true}
      ],
      "rubric_score_target": 90
    },
    {
      "id": "multi-turn-training",
      "description": "测试使用对话历史进行多轮训练的能力",
      "mode": "TUNE",
      "turns": [
        {"role": "user", "content": "对 git-release Skill 进行多轮训练，提供最近 8 轮对话历史和 Eval 报告"},
        {"role": "tool", "content": "Eval report received: MultiTurnPassRate=78%"},
        {"role": "user", "content": "根据历史生成优化版本"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "context_persistence", "value": true},
        {"type": "optimization_diff_generated", "value": true}
      ],
      "rubric_score_target": 88
    },
    {
      "id": "security-review",
      "description": "测试 OWASP AST10 安全审查能力",
      "mode": "SECURITY",
      "turns": [
        {"role": "user", "content": "对当前 Skill 执行 OWASP AST10 安全审查"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "owasp_checklist_applied", "value": true}
      ]
    },
    {
      "id": "restore-underperforming-skill",
      "description": "测试修复低分技能的能力",
      "mode": "RESTORE",
      "turns": [
        {"role": "user", "content": "修复 skill-manager 中低分的触发词检测，当前 Mode Detection 只有 49%"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "restore_mode_activated", "value": true},
        {"type": "trigger_optimization_performed", "value": true}
      ]
    },
    {
      "id": "tune-self-optimization",
      "description": "测试自优化循环",
      "mode": "TUNE",
      "turns": [
        {"role": "user", "content": "对 skill-manager 执行自优化，目标 Runtime Score 达到 9.5"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "tune_mode_activated", "value": true},
        {"type": "optimization_loop_executed", "value": true}
      ]
    },
    {
      "id": "evaluate-certify-skill",
      "description": "测试技能评估和认证",
      "mode": "EVALUATE",
      "turns": [
        {"role": "user", "content": "评估 code-review Skill 并给出 CERTIFIED 状态"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "evaluation_mode_activated", "value": true},
        {"type": "certification_determined", "value": true}
      ]
    },
    {
      "id": "zh-trigger-create",
      "description": "测试中文触发词 - 创建技能",
      "mode": "CREATE",
      "turns": [
        {"role": "user", "content": "创建技能：一个用于代码审查的 skill"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "zh_trigger_detected", "value": true},
        {"type": "create_mode_activated", "value": true}
      ]
    },
    {
      "id": "zh-trigger-tune",
      "description": "测试中文触发词 - 自优化",
      "mode": "TUNE",
      "turns": [
        {"role": "user", "content": "自优化这个 skill，让它达到 PLATINUM 状态"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "zh_trigger_detected", "value": true},
        {"type": "tune_mode_activated", "value": true}
      ]
    },
    {
      "id": "mode-detection-ambiguous",
      "description": "测试歧义输入处理",
      "mode": "EVALUATE",
      "turns": [
        {"role": "user", "content": "improve my skill score"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "ambiguous_input_handled", "value": true},
        {"type": "user_prompted_for_clarification", "value": true}
      ]
    },
    {
      "id": "mode-detection-improve",
      "description": "测试 improve 歧义（可以是 TUNE 或 EVALUATE）",
      "turns": [
        {"role": "user", "content": "improve my skill"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "mode_routing_correct", "value": true}
      ]
    },
    {
      "id": "runtime-validation",
      "description": "测试运行时验证流程",
      "mode": "EVALUATE",
      "turns": [
        {"role": "user", "content": "运行 runtime-validate.sh 验证 skill-manager"}
      ],
      "should_trigger": true,
      "assertions": [
        {"type": "runtime_validation_executed", "value": true},
        {"type": "mode_detection_reported", "value": true}
      ]
    }
  ],
  "metadata": {
    "total_cases": 12,
    "multi_turn_ratio": 0.6,
    "multi_agent_focus": true,
    "security_focus": true,
    "mode_coverage": {
      "CREATE": 3,
      "EVALUATE": 3,
      "RESTORE": 1,
      "TUNE": 3,
      "SECURITY": 1
    }
  }
}
